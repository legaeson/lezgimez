{
  "name": "lezgimez",
  "version": "2.2.11-beta",
  "description": "Lezgian language learning PWA with dictionary, grammar, SRS and offline support",
  "main": "sw.js",
  "scripts": {
    "build": "tailwindcss -i input.css -o output.css --minify",
    "dev": "tailwindcss -i input.css -o output.css --watch",
    "serve": "node scripts/serve.cjs",
    "validate": "node scripts/validate-words.cjs",
    "test": "node scripts/sync-js.cjs && node test.cjs && npm run validate",
    "quality": "npm test && npm run build",
    "export": "node scripts/export.cjs"
  },
  "keywords": [
    "lezgi",
    "lezgian",
    "pwa",
    "learning",
    "srs"
  ],
  "author": "LezgiMez",
  "license": "ISC",
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  }
}
