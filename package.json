{
  "name": "lezgimez",
  "version": "2.2.6",
  "type": "module",
  "description": "Lezgian language learning PWA with dictionary, grammar, SRS and offline support",
  "main": "sw.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/copy-assets.cjs",
    "preview": "npm run build && wrangler dev",
    "validate": "node scripts/validate-words.cjs",
    "test": "node test.cjs && npm run validate",
    "quality": "npm test && npm run build",
    "deploy": "npm run build && wrangler deploy"
  },
  "keywords": [
    "lezgi",
    "lezgian",
    "pwa",
    "learning",
    "srs"
  ],
  "author": "LezgiMez",
  "license": "ISC",
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "^4.100.0"
  }
}
